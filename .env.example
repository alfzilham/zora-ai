# ================================
# DATABASE
# ================================
DATABASE_URL=postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/zoradb?sslmode=require

# ================================
# JWT AUTH
# ================================
JWT_SECRET=buatSendiriRandom32KarakterMinimal!
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ================================
# GOOGLE OAUTH
# ================================
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# ================================
# NVIDIA AI MODELS (per model)
# ================================
NVIDIA_API_KEY_NEMOTRON=nvapi-xxxx   # nemotron-3-super-120b-a12b
NVIDIA_API_KEY_DEEPSEEK=nvapi-xxxx   # deepseek-v3.2
NVIDIA_API_KEY_QWEN=nvapi-xxxx       # qwen3.5-122b-a10b
NVIDIA_API_KEY_KIMI=nvapi-xxxx       # kimi-k2.5
NVIDIA_API_KEY_MINIMAX=nvapi-xxxx    # minimax-m2.7
NVIDIA_API_KEY_GLM=nvapi-xxxx        # glm-5.1
NVIDIA_API_KEY_GEMMA=nvapi-xxxx      # gemma-4-31b-it
NVIDIA_API_KEY_MISTRAL=nvapi-xxxx    # mistral-small-4-119b-2603
NVIDIA_API_KEY_FALLBACK=nvapi-xxxx   # key cadangan semua model

# ================================
# AI MODELS
# ================================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxx

# ================================
# ZORA LABS
# ================================
VIDEO_API_ENABLED=false

# ================================
# PAYMENT
# ================================
XENDIT_SECRET_KEY=xnd_development_xxxxxxxx
XENDIT_WEBHOOK_TOKEN=xxxxxxxxxxxxxxxx

# ================================
# APP CONFIG
# ================================
APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENV=development