{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/static/(.*)", "dest": "/api/index.py" },
    { "src": "/", "dest": "/frontend/public/index.html" },
    { "src": "/(.*\\.html)", "dest": "/frontend/public/$1" },
    { "src": "/(.*\\.css)", "dest": "/frontend/public/$1" },
    { "src": "/(.*\\.js)", "dest": "/frontend/public/$1" },
    { "src": "/(.*\\.png|.*\\.jpg|.*\\.ico|.*\\.webp|.*\\.svg)", "dest": "/frontend/public/$1" },
    { "src": "/(.*)", "dest": "/frontend/public/$1" }
  ]
}